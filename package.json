{
  "name": "tsdoc-enforcer-action",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub Action that enforces TSDoc on TypeScript PRs and generates paste-ready doc blocks via Claude.",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/suggest/index.ts -o dist --license licenses.txt",
    "build:report": "ncc build src/report/index.ts -o report/dist --license licenses.txt",
    "build:reply": "ncc build src/suggest/reply.ts -o reply/dist --license licenses.txt",
    "build:all": "npm run build && npm run build:report && npm run build:reply",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "all": "npm run typecheck && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stephengeller/tsdoc-enforcer-action.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@anthropic-ai/sdk": "^0.90.0",
    "@octokit/rest": "^21.0.2",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vercel/ncc": "^0.38.1",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
